{
  "name": "portfolio-site",
  "version": "1.0.0",
  "license": "MIT",
  "scripts": {
    "ng": "ng",
    "start": "ng serve --open",
    "docker-start": "ng serve  --host 0.0.0.0",
    "build": "ng build",
    "test": "npm run lint && ng test --configuration=test",
    "lint": "ng lint",
    "watch": "ng test --configuration=test --browsers ChromeHeadless --watch",
    "build:dev": "ng build --configuration=dev",
    "build:stg": "ng build  --configuration=staging",
    "build:prod": "ng build --configuration=production",
    "clean": "rimraf ./dist/",
    "ci": "npm run clean && npm run format:test && ng lint && ng test --configuration=test --browsers ChromeHeadless --code-coverage && npm run build:prod",
    "release": "standard-version && git push --follow-tags origin master",
    "format:write": "prettier src/**/*.{ts,json,md,scss} --write",
    "format:test": "prettier src/**/*.{ts,json,md,scss} --list-different",
    "analyze": "npm run clean && npm run build:prod -- --stats-json && webpack-bundle-analyzer ./dist/stats.json",
    "compodoc": "compodoc -p src/tsconfig.app.json"
  },
  "lint-staged": {
    "src/**/*.{ts,json,md,scss}": [
      "prettier --write",
      "git add"
    ]
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "^18.2.14",
    "@angular/cdk": "^18.2.14",
    "@angular/common": "^18.2.14",
    "@angular/compiler": "^18.2.14",
    "@angular/core": "^18.2.14",
    "@angular/forms": "^18.2.14",
    "@angular/material": "^18.2.14",
    "@angular/platform-browser": "^18.2.14",
    "@angular/platform-browser-dynamic": "^18.2.14",
    "@angular/router": "^18.2.14",
    "@fortawesome/angular-fontawesome": "^0.11.1",
    "@fortawesome/fontawesome-free": "^6.1.1",
    "@fortawesome/fontawesome-svg-core": "^6.1.1",
    "@fortawesome/free-brands-svg-icons": "^6.1.1",
    "@fortawesome/free-solid-svg-icons": "^6.1.1",
    "@ngrx/effects": "^17.2.0",
    "@ngrx/entity": "^17.2.0",
    "@ngrx/router-store": "^17.2.0",
    "@ngrx/schematics": "^17.2.0",
    "@ngrx/store": "^17.2.0",
    "@ngrx/store-devtools": "^17.2.0",
    "@ngx-formly/core": "^6.3.12",
    "@ngx-formly/material": "^6.3.12",
    "@ngx-formly/schematics": "^6.3.12",
    "@ngx-translate/core": "^14.0.0",
    "@ngx-translate/http-loader": "^7.0.0",
    "bootstrap": "^5.1.3",
    "browser-detect": "^0.2.28",
    "core-js": "^3.23.2",
    "google-libphonenumber": "^3.2.18",
    "hammerjs": "^2.0.8",
    "intl-tel-input": "^17.0.12",
    "ng-http-loader": "^12.0.0",
    "ng-recaptcha": "^10.0.0",
    "ngx-bootstrap": "^9.0.0",
    "rxjs": "^7.5.5",
    "three": "^0.185.1",
    "tslib": "^2.4.0",
    "web-animations-js": "^2.3.2",
    "zone.js": "^0.14.10"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^18.2.21",
    "@angular/cli": "^18.2.21",
    "@angular/compiler-cli": "^18.2.14",
    "@angular/language-service": "^18.2.14",
    "@compodoc/compodoc": "^1.1.19",
    "@testing-library/angular": "^12.0.2",
    "@types/jasmine": "^4.0.3",
    "@types/node": "^18.0.0",
    "@types/three": "^0.185.1",
    "codelyzer": "~6.0.2",
    "husky": "^8.0.1",
    "jasmine-core": "~4.2.0",
    "jasmine-marbles": "^0.9.2",
    "jasmine-spec-reporter": "~7.0.0",
    "karma": "^6.4.0",
    "karma-chrome-launcher": "~3.1.1",
    "karma-coverage-istanbul-reporter": "^3.0.3",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "^2.0.0",
    "karma-spec-reporter": "~0.0.34",
    "lint-staged": "^13.0.2",
    "prettier": "^2.7.1",
    "rimraf": "^3.0.2",
    "standard-version": "^9.5.0",
    "ts-node": "^10.8.1",
    "tslint": "^6.1.3",
    "typescript": "~5.5.4",
    "webpack-bundle-analyzer": "^4.5.0"
  }
}
